# Supabase — get these from your project (or `supabase start` output locally).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=

# Core boundary REST fallback (only used if the scoring core is a SEPARATE
# service — see TODO(rizzfitt) in supabase migration 3). Server-only.
# CORE_API_KEY: Bearer token the core sends to GET /api/core/entry-list.
# CORE_SHARED_SECRET: HMAC key for the x-core-signature on POST /api/core/results.
CORE_API_KEY=
CORE_SHARED_SECRET=
